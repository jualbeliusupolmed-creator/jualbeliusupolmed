# ── Template environment variables ──
# Salin file ini menjadi `.env.local` lalu isi dengan nilai asli.
# JANGAN pernah menuliskan nilai rahasia asli di file ini (file ini ikut ter-commit).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # RAHASIA, server-only
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
# Fonnte (WhatsApp gateway fallback)
FONNTE_TOKEN=your_fonnte_token
FONNTE_WA_GROUP_ID=xxxxxxxxxx@g.us

# Baileys (WhatsApp gateway utama)
BAILEYS_API_URL=https://wa-bot-usu-production.up.railway.app
BAILEYS_API_TOKEN=jualbeliusu_rahasia

# Admin & kontak
ADMIN_PASSWORD=ganti_dengan_password_kuat
MARKETPLACE_WA=628xxxxxxxxxx
NEXT_PUBLIC_MARKETPLACE_WA=628xxxxxxxxxx
NEXT_PUBLIC_WA_GROUP_LINK=https://chat.whatsapp.com/xxxxxxxx

# Situs
NEXT_PUBLIC_BASE_URL=https://www.jualbeliusupolmed.web.id

# Cron (lindungi endpoint /api/cron/*)
CRON_SECRET=your_random_secret
